generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  idToken               String?   @db.Text
  scope                 String?
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model AuditLog {
  id         String         @id @default(cuid())
  workflowId String?
  eventType  AuditEventType
  actorId    String
  ipAddress  String
  userAgent  String
  metadata   Json?
  timestamp  DateTime       @default(now())
  actor      User           @relation(fields: [actorId], references: [id])
  workflow   Workflow?      @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([timestamp])
  @@index([workflowId])
}

model DriveSettings {
  id             String  @id @default(cuid())
  userId         String  @unique
  saveLocation   String  @default("SAME_FOLDER")
  targetFolderId String?
  namingPattern  String  @default("{name}_Signed_{date}")
  autoSave       Boolean @default(true)
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model SignatureField {
  id          String    @id @default(cuid())
  workflowId  String
  signerId    String
  type        FieldType
  page        Int
  x           Float
  y           Float
  width       Float
  height      Float
  value       String?
  completedAt DateTime?
  signer      Signer    @relation(fields: [signerId], references: [id], onDelete: Cascade)
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([signerId])
  @@index([workflowId])
}

model Signer {
  id                 String           @id @default(cuid())
  workflowId         String
  userId             String?
  email              String
  name               String
  order              Int
  status             SignerStatus     @default(PENDING)
  consentGiven       Boolean          @default(false)
  consentTimestamp   DateTime?
  signedAt           DateTime?
  lastReminderSentAt DateTime?
  fields             SignatureField[]
  user               User?            @relation(fields: [userId], references: [id])
  workflow           Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([status])
  @@index([workflowId])
}

model User {
  id                      String         @id @default(cuid())
  email                   String         @unique
  name                    String
  emailVerified           Boolean        @default(false)
  image                   String?
  company                 String?
  title                   String?
  passwordHash            String?
  twoFactorSecret         String?
  locale                  String         @default("en")
  timezone                String         @default("UTC")
  notificationPreferences Json?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  accounts                Account[]
  auditLogs               AuditLog[]
  driveSettings           DriveSettings?
  sessions                Session[]
  signers                 Signer[]
  workflows               Workflow[]     @relation("CreatedBy")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
}

model Workflow {
  id             String           @id @default(cuid())
  name           String
  status         WorkflowStatus   @default(DRAFT)
  creatorId      String
  driveFileId    String
  driveFolderId  String?
  documentHash   String
  signedFileId   String?
  retentionDate  DateTime?
  documentNumber String?          @unique
  documentType   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  completedAt    DateTime?
  cancelledAt    DateTime?
  auditLogs      AuditLog[]
  fields         SignatureField[]
  signers        Signer[]
  creator        User             @relation("CreatedBy", fields: [creatorId], references: [id])

  @@index([creatorId])
  @@index([status])
}

enum AuditEventType {
  WORKFLOW_CREATED
  SIGNER_NOTIFIED
  SIGNING_STARTED
  FIELD_SIGNED
  SIGNING_COMPLETED
  WORKFLOW_COMPLETED
  WORKFLOW_CANCELLED
  REMINDER_SENT
  AUTH_SUCCESS
  AUTH_FAILURE
  WORKFLOW_DELETED
}

enum FieldType {
  SIGNATURE
  INITIALS
  DATE
}

enum SignerStatus {
  PENDING
  NOTIFIED
  SIGNING
  SIGNED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}
